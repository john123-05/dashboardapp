{
  "expo": {
    "name": "Liftpictures Dashboard",
    "slug": "dashboardapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ride.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "dashboardapp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/ride.png",
      "bundleIdentifier": "com.john12305.dashboardapp",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.john12305.dashboardapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/ride.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "976d7cfc-6559-485a-902d-5724536a1d85"
      }
    },
    "owner": "johndurden"
  }
}
